# Stoke AI client portal
# Required in production. Use a long random value.
PORTAL_SESSION_SECRET=

# Client portal access codes. Supports JSON or comma-separated client:code pairs.
# JSON example:
# PORTAL_ACCESS_CODES={"rachel-hansen":"replace-me","handy-truck-lines":"replace-me","stoke-ai":"replace-me"}
PORTAL_ACCESS_CODES=

# Optional Trello sync. If unset, portal uses internal customer-safe board data.
TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_RACHEL_BOARD_ID=
TRELLO_HTL_BOARD_ID=
TRELLO_STOKE_BOARD_ID=
