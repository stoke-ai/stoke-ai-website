# Copy to .env.local for local development. Do not commit real secrets.

# Required in every deployed environment.
PORTAL_SESSION_SECRET="replace-with-random-secret"

# Required for client portal login. JSON form is preferred.
# Example shape only — replace codes locally/inside Vercel env.
PORTAL_ACCESS_CODES='{"goff-welding":"replace-me","rachel-hansen":"replace-me","handy-truck-lines":"replace-me","stoke-ai":"replace-me"}'

# Required for /admin/portal. Keep separate from client/demo portal credentials.
PORTAL_ADMIN_USERNAME="replace-with-admin-username"
PORTAL_ADMIN_PASSWORD="replace-with-admin-password"

# Required for current blob-backed portal persistence until the Postgres migration is complete.
BLOB_READ_WRITE_TOKEN="replace-with-vercel-blob-token"

# Optional portal operations fan-out.
PORTAL_TELEGRAM_BOT_TOKEN=""
PORTAL_TELEGRAM_CHAT_ID=""
PORTAL_TELEGRAM_THREAD_ID=""
PORTAL_TRIAGE_WEBHOOK_URL=""
PORTAL_TRIAGE_WEBHOOK_SECRET=""

# Future durable DB-backed portal store.
DATABASE_URL=""
